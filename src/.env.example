# API Settings
PROJECT_NAME="FastAPI MVC Framework"
APP_VERSION="0.1"
API_PREFIX=/api/v1

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# MySQL Database Credentials
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=database_name

# AI: openai | local (OpenAI-compatible local server, e.g. Ollama)
AI_PROVIDER=openai

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-5-mini

# When AI_PROVIDER=local (default: Ollama native /api/chat; use .../v1/chat/completions for OpenAI-compatible only)
LOCAL_MODEL_API_URL=http://127.0.0.1:11434/api/chat
# Must match a name from `ollama list` exactly (e.g. gemma3-1b:latest)
LOCAL_MODEL_NAME=
LOCAL_MODEL_API_KEY=

# Optional overrides for both providers
AI_TEMPERATURE=0.0
AI_MAX_TOKENS=4096

# Rate Limiting Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=1000/hour
RATE_LIMIT_GET=200/minute
RATE_LIMIT_POST=50/minute
RATE_LIMIT_PUT=50/minute
RATE_LIMIT_DELETE=50/minute

# JWT Settings (required — replace with a strong secret, e.g. python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=replace-with-your-own-secret-min-1-char
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

