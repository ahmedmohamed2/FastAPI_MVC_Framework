# API Settings
PROJECT_NAME="FastAPI MVC Framework"
APP_VERSION="0.1"

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# ODBC Driver name (common options: "ODBC Driver 17 for SQL Server", "ODBC Driver 18 for SQL Server", "SQL Server")
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=

# Rate Limiting Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=1000/hour
RATE_LIMIT_GET=200/minute
RATE_LIMIT_POST=50/minute
RATE_LIMIT_PUT=50/minute
RATE_LIMIT_DELETE=50/minute

# JWT Settings
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-urlsafe-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

