# API Settings
PROJECT_NAME="FastAPI MVC Framework"
APP_VERSION="0.1"

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database Settings
DATABASE_URL=sqlite:///

# SQL Server Settings
# Authentication type: "sql" for SQL Authentication, "windows" for Windows Authentication
SQL_SERVER_AUTH_TYPE=
SQL_SERVER_HOST=
SQL_SERVER_PORT=
SQL_SERVER_DATABASE=
# For SQL Authentication (when SQL_SERVER_AUTH_TYPE=sql)
# For Windows Authentication (when SQL_SERVER_AUTH_TYPE=windows), leave username and password empty
SQL_SERVER_USERNAME=
SQL_SERVER_PASSWORD=
# ODBC Driver name (common options: "ODBC Driver 17 for SQL Server", "ODBC Driver 18 for SQL Server", "SQL Server")
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server

# Environment
ENVIRONMENT=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=

# Rate Limiting Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=1000/hour
RATE_LIMIT_GET=200/minute
RATE_LIMIT_POST=50/minute
RATE_LIMIT_PUT=50/minute
RATE_LIMIT_DELETE=50/minute

# JWT Settings
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-urlsafe-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


# MongoDB Settings
MONGODB_URI=mongodb://admin:<pass>@<host>:27017/
MONGODB_DATABASE=<Database_name>
